package main;

import std.prelude;

fn getAllPlayers() -> List<Player> {
    val uuids = gval("Plot Player UUIDs");
    var players: List<Player> = List.of();

    for (val uuid in uuids) {
        players.append(Player {
            uuid: uuid
        });
    }

    return players;
}

@Event
fn testPlayer(var event: PlayerJoinEvent) {
    for (var player in getAllPlayers()) {
        player.damage(5);
    }

    event.getPlayer().sendMessage(s"<green>Hello World");
    event.cancel();
}

