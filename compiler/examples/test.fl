fn playerNameEquals(name: String) -> Boolean {
    if emit `if_player "NameEquals" args($name$)` {
        return true;
    }
    return false;
}

fn test4() {
    if (playerNameEquals("zBinFinn")) {
        print(5);
    } else {
        print(6);
    }
}

fn print(num: Num) {
    emit `player_action "SendMessage" args($num$) tags(..)`;
}

fn increment(var num: Num) {
    num = num + 1;
}

fn sum(a: Num, b: Num) -> Num {
    return a + b;
}

fn test3() {
    val num1 = 5;
    var num2 = 3;
    increment(var num2); // only works for var not val and requires 'var' to make it clear that it is being mutated

    print(sum(num1, num2));
}

struct PlayerData {
    money: Num,
    name: String
}

fn test2() {
    val data = PlayerData {
        money: 5,
        name: "zBinFinn"
    }

    emit `player_action "SendMessage" args($data$) tags(..)`;
}
