inline fn List<T>.append(var this, element: T) {
    emit `set_variable "AppendValue" args($this$, $element$)`;
}

inline fn List<T>.get(this, index: Num) -> T {
    var out: T;
    emit `set_variable "GetListValue" args($out$, $this$, $index$)`;
    return out;
}

inline fn List<T>.set(var this, index: Num, element: T) {
    emit `set_variable "SetListValue" args($this$, $index$, $element$)`;
}

inline fn List<T>.length(this) -> Num {
    var out: Num;
    emit `set_variable "ListLength" args($out$, $this$)`;
    return out;
}

inline fn Dict<T>.new() -> Dict<T> {
    var keys: List<String>;
    emit `set_variable "CreateList" args($keys$)`;
    var values: List<T>;
    emit `set_variable "CreateList" args($values$)`;
    var out: Dict<T>;
    emit `set_variable "CreateDict" args($out$, $keys$, $values$)`;
    return out;
}

inline fn Dict<T>.get(this, key: String) -> T {
    var out: T;
    emit `set_variable "GetDictValue" args($out$, $this$, $key$)`;
    return out;
}

inline fn Dict<T>.set(var this, key: String, value: T) {
    emit `set_variable "SetDictValue" args($this$, $key$, $value$)`;
}

inline fn Dict<T>.keys(this) -> List<String> {
    var out: List<String>;
    emit `set_variable "GetDictKeys" args($out$, $this$)`;
    return out;
}

inline fn Dict<T>.values(this) -> List<T> {
    var out: List<T>;
    emit `set_variable "GetDictValues" args($out$, $this$)`;
    return out;
}

inline fn Dict<T>.size(this) -> Num {
    var out: Num;
    emit `set_variable "GetDictSize" args($out$, $this$)`;
    return out;
}
