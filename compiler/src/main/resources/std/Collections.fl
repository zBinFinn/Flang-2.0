package std;

inline fn List<T>.of() -> List<T> {
    var out: List<T>;
    emit `set_variable "CreateList" args($out$)`;
    return out;
}

inline fn List<T>.of(v1: T) -> List<T> {
    var out: List<T>;
    emit `set_variable "CreateList" args($out$, $v1$)`;
    return out;
}

inline fn List<T>.of(v1: T, v2: T) -> List<T> {
    var out: List<T>;
    emit `set_variable "CreateList" args($out$, $v1$, $v2$)`;
    return out;
}

inline fn List<T>.of(v1: T, v2: T, v3: T) -> List<T> {
    var out: List<T>;
    emit `set_variable "CreateList" args($out$, $v1$, $v2$, $v3$)`;
    return out;
}

inline fn List<T>.of(v1: T, v2: T, v3: T, v4: T) -> List<T> {
    var out: List<T>;
    emit `set_variable "CreateList" args($out$, $v1$, $v2$, $v3$, $v4$)`;
    return out;
}

