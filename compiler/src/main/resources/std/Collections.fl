    emit `set_variable "CreateList" args($out$, $v1$, $v2$, $v3$, $v4$, $v5$, $v6$, $v7$, $v8$)`;
    return out;
}

inline fn List<T>.of(v1: T, v2: T, v3: T, v4: T, v5: T, v6: T, v7: T, v8: T, v9: T) -> List<T> {
    var out: List<T>;
    emit `set_variable "CreateList" args($out$, $v1$, $v2$, $v3$, $v4$, $v5$, $v6$, $v7$, $v8$, $v9$)`;
